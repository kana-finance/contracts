# Kana Finance — Deploy Environment Variables
# Copy to .env and fill in values before deploying

# Deployer private key (EOA that will deploy and seed the vault)
PRIVATE_KEY=0x...

# SEI EVM RPC endpoint
SEI_RPC_URL=https://evm-rpc.sei-apis.com

# Guardian address — pause-only role (cold wallet or dedicated guardian EOA)
GUARDIAN_ADDRESS=0x...

# Multisig address — receives ownership after deploy (Gnosis Safe or similar)
MULTISIG_ADDRESS=0x...

# Optional: Merkl distributor address for Morpho reward claiming
# Leave empty to skip setMerklDistributor during deploy
# MERKL_DISTRIBUTOR_ADDRESS=0x...
